{
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "es2022",
    "moduleResolution": "Node", 
    "types": ["vite/client"],   
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
        "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    ".",
    "src",
    "../shared"          /* make sure TS will type‑check the shared code */
  ]  
}
