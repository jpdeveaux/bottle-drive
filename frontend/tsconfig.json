{
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "es2022",
    "moduleResolution": "Node", 
    "types": ["vite/client"],   
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
        "@shared/*": ["../shared/*"],
        "@context/*": ["src/context/*"],
        "@hooks/*": ["src/hooks/*"],
        "@components/*": ["src/components/*"],
        "@auth": ["src/authFetch.js"]
    }
  },
  "include": [
    ".",
    "src",
    "../shared"          /* make sure TS will type‑check the shared code */
  ]  
}
