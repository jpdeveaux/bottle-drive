# The DATABASE_URL variable is only for local connections, but can remain for production.

# general settings
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000   # switch to your production frontend URL when deploying
BACKEND_URL=http://localhost:3001
INITIAL_ADMIN_EMAIL=yourname@gmail.com
INITIAL_ADMIN_NAME=Your Name
JWT_SECRET=supersecret

# database settings
DB_USER=dbUser
DB_PASS=dbPass
DB_NAME=bottledrive
DB_PORT=5432
DATABASE_URL="postgresql://dbUser:dbPass@localhost:5432/bottledrive?schema=public"

# frontend environment variables
VITE_TITLE="Bottle Drive"
VITE_API_URL=http://localhost:3001
VITE_MAP_CENTER_LAT=44.6488
VITE_MAP_CENTER_LNG=-63.5752
VITE_MAP_ZOOM=13
VITE_ADDRESS_PLACEHOLDER="123 Main St, Halifax, NS"
VITE_GOOGLE_CLIENT_ID=469185492956-lj0hlj0qpd47th34ssss4r9t9tfivl80.apps.googleusercontent.com