{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",                /* Required for modern Node.js */
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,            /* Required for the 'pg' library */
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": "./",
    "paths": {
      "@routes/*": ["src/routes/*"],
      "@auth": ["src/middleware/auth.js"],
      "@types": ["src/types.js"],
    }
  },
  "include": [
    "src/**/*"],
  "exclude": ["node_modules", "dist"]
}