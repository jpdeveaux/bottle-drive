{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",                /* Required for modern Node.js */
    "moduleResolution": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,            /* Required for the 'pg' library */
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*", "prisma/generated-client/*"] 
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}