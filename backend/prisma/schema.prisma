// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  role       Role     @default(volunteer)
  googleId   String?  @unique
  isApproved Boolean  @default(false) 

  // The Heartbeat Fields
  lastLat          Float?
  lastLng          Float?
  lastSeen         DateTime?

  // link to addresses for audit trail
  updatedAddresses Address[]

  zones      Zone[]   @relation("UserZones")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model Zone {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#3b82f6") // Default Tailwind Blue-500
  addresses Address[]

  // Geographic bounds for redrawing the rectangle on the map
  north     Float?
  south     Float?
  east      Float?
  west      Float?

  users     User[]   @relation("UserZones")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt  
}

model Address {
  id        String   @id @default(uuid())
  street    String
  lat       Float
  lng       Float
  status    AddressStatus @default(unvisited)
  notes     String?

  zoneId    String?
  zone      Zone?     @relation(fields: [zoneId], references: [id])

  updatedById String?
  updater   User?    @relation(fields: [updatedById], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

enum Role {
  admin
  volunteer
}

enum AddressStatus {
  unvisited
  completed
}