// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  role       Role     @default(volunteer)
  googleId   String?  @unique
  isApproved Boolean  @default(false) 
  createdAt  DateTime @default(now())

  zones      Zone[]   @relation("ZoneClaims")

  // link to addresses for audit trail
  updatedAddresses Address[]
}

model Zone {
  id        String   @id @default(uuid())
  name      String
  color     String
  status    ZoneStatus @default(unclaimed)
  claimedAt DateTime?
  claimedBy String?

  claimer   User?    @relation("ZoneClaims", fields: [claimedBy], references: [id])
//  addresses Address[]

  createdAt DateTime @default(now())
}

model Address {
  id        String   @id @default(uuid())
  street    String
  lat       Float
  lng       Float
  status    AddressStatus @default(unvisited)
  notes     String?
  createdAt DateTime @default(now())

//  zoneId    String
//  zone      Zone     @relation(fields: [zoneId], references: [id])

  updatedById String?
  updater   User?    @relation(fields: [updatedById], references: [id])
}

enum Role {
  admin
  volunteer
}

enum ZoneStatus {
  unclaimed
  claimed
  completed
}

enum AddressStatus {
  unvisited
  completed
}